{
  "manifest_version": 3,
  "name": "Netflix/TVer/DOWNTOWN+/ABEMA 5 Second Seek",
  "version": "1.0.0",
  "description": "Netflix、TVer、DOWNTOWN+、ABEMA の再生画面で左右キーのシーク秒数を 5 秒に変更します。",
  "web_accessible_resources": [
    {
      "resources": [
        "netflix-page.js"
      ],
      "matches": [
        "https://www.netflix.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.netflix.com/*",
        "https://tver.jp/*",
        "https://www.tver.jp/*",
        "https://downtownplus.com/*",
        "https://www.downtownplus.com/*",
        "https://abema.tv/*",
        "https://www.abema.tv/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
